# Copy relevant values into your real .env (which already has DATABASE_URL configured)

# --- Authentication ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
DEFAULT_ADMIN_EMAIL=admin@neetctk.com
DEFAULT_ADMIN_PASSWORD=ctk-admin-2026
ADMIN_SIGNUP_CODE=ctk-admin-invite

# --- Email (OTP delivery). If left unset, OTPs are logged to the server
# console instead of emailed — useful for local development. ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="NEET CTK IGNITION <your-email@gmail.com>"

# --- Free AI model for mistake-analysis recommendations (optional) ---
# Get a free token at https://huggingface.co/settings/tokens
# If unset, the rule-based recommendation engine is used instead.
HF_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
